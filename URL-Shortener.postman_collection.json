    },
    {
      "name": "URL Management",
      "description": "Protected endpoints for managing your shortened URLs.\n\n**Auth (send one):**\n- Logged-in user → `Authorization: Bearer {{authToken}}`\n- Guest → `X-Guest-Id: {{guestId}}`\n\nEach caller only sees and can modify their own links.",
      "item": [
        {
          "name": "List All URLs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}", "description": "Use this for logged-in users" },
              { "key": "X-Guest-Id",    "value": "{{guestId}}",          "description": "Use this for guest users", "disabled": true }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/urls?page=1&limit=20&active=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls"],
              "query": [
                { "key": "page",   "value": "1",    "description": "Page number (default 1)" },
                { "key": "limit",  "value": "20",   "description": "Items per page, max 100 (default 20)" },
                { "key": "active", "value": "true", "description": "Filter to active URLs only (true/false)" },
                { "key": "search", "value": "",     "description": "Full-text search across URL, title, and tags", "disabled": true },
                { "key": "tag",    "value": "",     "description": "Filter by tag", "disabled": true }
              ]
            },
            "description": "Returns a paginated list of all shortened URLs. Supports full-text search and tag filtering."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"data\": [\n    {\n      \"_id\": \"64f1a2b3c4d5e6f7a8b9c0d1\",\n      \"shortCode\": \"aB3xY7z\",\n      \"shortUrl\": \"http://localhost:3000/aB3xY7z\",\n      \"originalUrl\": \"https://www.example.com/long/url\",\n      \"title\": \"Example Page\",\n      \"isActive\": true,\n      \"clickCount\": 42,\n      \"expiresAt\": null,\n      \"createdAt\": \"2026-02-28T12:00:00.000Z\"\n    }\n  ],\n  \"pagination\": {\n    \"total\": 1,\n    \"page\": 1,\n    \"limit\": 20,\n    \"totalPages\": 1\n  }\n}",
              "_postman_previewlanguage": "json"
            }
          ]
        },
        {
          "name": "Get Single URL",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "X-Guest-Id",    "value": "{{guestId}}",          "disabled": true }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/urls/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls", "{{shortCode}}"]
            },
            "description": "Returns all stored metadata for a single shortened URL by its short code."
          },
          "response": []
        },
        {
          "name": "Update URL",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "X-Guest-Id",    "value": "{{guestId}}",          "disabled": true },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"https://www.updated-destination.com\",\n  \"isActive\": true,\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\",\n  \"tags\": [\"updated\"],\n  \"expiresAt\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/urls/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls", "{{shortCode}}"]
            },
            "description": "Update any field of an existing short URL. All fields are optional — only send what you want to change.\n\n- Set `isActive: false` to disable/deactivate a link without deleting it.\n- Set `expiresAt: null` to remove expiry."
          },
          "response": []
        },
        {
          "name": "Deactivate URL",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "X-Guest-Id",    "value": "{{guestId}}",          "disabled": true },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/urls/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls", "{{shortCode}}"]
            },
            "description": "Quick helper to disable a short URL without deleting it. Returns 410 to visitors."
          },
          "response": []
        },
        {
          "name": "Delete URL",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "X-Guest-Id",    "value": "{{guestId}}",          "disabled": true }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/urls/{{shortCode}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "urls", "{{shortCode}}"]
            },
            "description": "Permanently deletes the short URL **and all associated click logs**."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"message\": \"URL and its click logs deleted.\"\n}",
              "_postman_previewlanguage": "json"
            }
          ]
        }
      ]
    },
    {
      "name": "Analytics & Stats",
      "description": "Protected analytics endpoints. Pass `?days=N` (1–365, default 30) to control the reporting window.\n\n**Note:** Dashboard Overview requires a logged-in JWT user. Per-URL stats and logs work for both logged-in users and guests (owner-scoped).",
      "item": [
        {
          "name": "Dashboard Overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/stats?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats"],
              "query": [{ "key": "days", "value": "30", "description": "Reporting window in days (1–365)" }]
            },
            "description": "Aggregate stats across **all** shortened URLs:\n- Summary (totalUrls, activeUrls, totalClicks, recentClicks)\n- Top 10 URLs by click count\n- Clicks per day (filled series)\n- Top countries, browsers, device types, referrers"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"data\": {\n    \"summary\": {\n      \"totalUrls\": 15,\n      \"activeUrls\": 12,\n      \"totalClicks\": 1042,\n      \"recentClicks\": 280,\n      \"periodDays\": 30\n    },\n    \"topUrls\": [...],\n    \"clicksByDay\": [{\"date\": \"2026-02-01\", \"count\": 12}, ...],\n    \"topCountries\": [{\"country\": \"Egypt\", \"count\": 320}, ...],\n    \"topBrowsers\": [{\"browser\": \"Chrome\", \"count\": 610}, ...],\n    \"topDevices\": [{\"deviceType\": \"mobile\", \"count\": 540}, ...],\n    \"topReferrers\": [{\"referrer\": \"twitter.com\", \"count\": 95}, ...]\n  }\n}",
              "_postman_previewlanguage": "json"
            }
          ]
        },
        {
          "name": "Per-URL Analytics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "X-Guest-Id",    "value": "{{guestId}}",          "disabled": true }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/stats/{{shortCode}}?days=30",
              "host": ["{{baseUrl}}"],
              "path": ["api", "stats", "{{shortCode}}"],
              "query": [{ "key": "days", "value": "30" }]
            },
            "description": "Deep analytics for a single short URL:\n- Total clicks and unique visitors\n- Clicks per day (filled series) and clicks by hour-of-day\n- Breakdown by country, browser, OS, device type, referrer\n- 50 most recent raw click records"
          },
          "response": [
            {
              "name": "200 OK",
